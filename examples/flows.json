{
  "version": 1,
  "data": [
    {
      "id": "startup_greeting",
      "name": "Startup Greeting",
      "enabled": true,
      "triggers": ["startup_timer"],
      "steps": [
        {
          "id": "notify_step",
          "type": "action",
          "action": "send_notification",
          "params": {
            "summary": "Automagic",
            "body": "Automagic is online and ready."
          },
          "goto_alt": "end"
        }
      ]
    },
    {
      "id": "startup_states",
      "name": "Startup States",
      "enabled": true,
      "triggers": ["startup_timer"],
      "steps": [
        {
          "id": "step_1",
          "type": "action",
          "function": "set_state",
          "params": {
            "name": "automagic_ready",
            "static": true
          },
          "goto_alt": "end"
        },
        {
          "id": "step_4",
          "type": "get",
          "function": "time",
          "mapping": { "hour": "start_hour", "minute": "start_minute", "second": "start_second" },
          "goto_alt": "end"
        },
        {
          "id": "step_5",
          "type": "action",
          "function": "set_state",
          "params": {
            "name": "startup_time",
            "template": "{{start_hour}}:{{start_minute}}:{{start_second}}"
          },
          "goto_alt": "end"
        },
        {
          "id": "step_8",
          "type": "get",
          "source": "system_hostname",
          "mapping": { "hostname": "hostname" },
          "goto_alt": "end"
        },
        {
          "id": "step_9",
          "type": "action",
          "function": "set_state",
          "params": {
            "name": "hostname",
            "variable": "hostname"
          },
          "goto_alt": "end"
        }
      ]
    },
    {
      "id": "battery_sync",
      "name": "Sync Battery State",
      "enabled": true,
      "triggers": ["battery_signal"],
      "steps": [
        {
          "id": "save_state",
          "type": "action",
          "function": "set_state",
          "params": {
            "name": "battery_level",
            "variable": "battery_level"
          },
          "goto_alt": "end"
        }
      ]
    }
  ]
}
