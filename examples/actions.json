{
  "version": 1,
  "data": [
    {
      "id": "log",
      "name": "Log Message",
      "type": "log",
      "params": {
        "message": "message"
      }
    },
    {
      "id": "send_notification",
      "name": "Send Desktop Notification",
      "type": "dbus_method",
      "enabled": true,
      "timeout_ms": 1000,
      "address": "session",
      "destination": "org.freedesktop.Notifications",
      "path": "/org/freedesktop/Notifications",
      "interface": "org.freedesktop.Notifications",
      "method": "Notify",
      "args": [
        {"type": "s", "value": "automagic"},
        {"type": "u", "value": 0},
        {"type": "s", "value": ""},
        {"type": "s", "value": "{{summary}}"},
        {"type": "s", "value": "{{body}}"},
        {"type": "as", "value": []},
        {"type": "a{sv}", "value": {}},
        {"type": "i", "value": 5000}
      ]
    },
    {
      "id": "send_sms",
      "name": "Send SMS",
      "type": "dbus_method",
      "enabled": true,
      "address": "system",
      "destination": "org.ofono",
      "path": "/ril_0",
      "interface": "org.ofono.MessageManager",
      "method": "SendMessage",
      "args": [
        {"type": "s", "value": "{{number}}"},
        {"type": "s", "value": "{{text}}"}
      ]
    }
  ]
}
