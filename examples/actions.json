{
  "version": 1,
  "data": [
    {
      "id": "log",
      "name": "Log Message",
      "type": "log",
      "params": {
        "message": "message"
      }
    },
    {
      "id": "send_notification",
      "name": "Send Desktop Notification",
      "type": "dbus_method",
      "enabled": true,
      "timeout_ms": 1000,
      "address": "session",
      "destination": "org.freedesktop.Notifications",
      "path": "/org/freedesktop/Notifications",
      "interface": "org.freedesktop.Notifications",
      "method": "Notify",
      "args": [
        {"type": "s", "value": "automagic"},
        {"type": "u", "value": 0},
        {"type": "s", "value": ""},
        {"type": "s", "value": "{{summary}}"},
        {"type": "s", "value": "{{body}}"},
        {"type": "as", "value": []},
        {"type": "a{sv}", "value": {}},
        {"type": "i", "value": 5000}
      ]
    },
    {
      "id": "send_sms",
      "name": "Send SMS",
      "type": "dbus_method",
      "enabled": true,
      "address": "system",
      "destination": "org.ofono",
      "path": "/ril_0",
      "interface": "org.ofono.MessageManager",
      "method": "SendMessage",
      "args": [
        {"type": "s", "value": "{{number}}"},
        {"type": "s", "value": "{{text}}"}
      ]
    },
    {
      "id": "write_data_temperature_humidity",
      "name": "Write Data Temperature/Humidity",
      "type": "write_data",
      "params": {
        "_data_record_name": "sensor_id",
        "humidity": "humidity",
        "temperature": "temperature"
      }
    },
    {
      "id": "post_to_api",
      "name": "POST to API",
      "type": "http",
      "method": "POST",
      "address": "https://qml.app/automagic/result.php",
      "content_type": "application/json",
      "payload": "{\"calculated_number\": \"{{value}}}",
      "username": "super",
      "password": "secret"
    },
    {
      "id": "mqtt_publish",
      "name": "Generic MQTT Publisher",
      "type": "mqtt_publish",
      "address": "tcp://192.168.8.12:1883",
      "username": "super",
      "password": "secret"
    },
    {
      "id": "write_sqlite_sales",
      "name": "Write Sales to Database",
      "type": "sqlite_query",
      "path": "/home/defaultuser/Documents/sales.sqlite",
      "query": "INSERT INTO phone_stats (sold, total) VALUES ({{phones_sold}}, {{phones_total}});"
    },
    {
      "id": "write_sensor_temperature",
      "name": "Write Temperature to MySQL",
      "type": "mysql_query",
      "address": "192.168.8.12",
      "database": "sensordata",
      "username": "secret",
      "password": "secret",
      "query": "INSERT INTO temperatures (sensor_id,temperature) VALUES ('{{sensor_id}}','{{temperature}}');"
    },
    {
      "id": "send_email",
      "name": "Send Email",
      "type": "smtp",
      "address": "192.168.8.101",
      "username": "secret",
      "password": "secret",
      "from": "defaultuser@qml.app",
      "to": "defaultuser@qml.app",
      "subject": "",
      "body": ""
    },
    {
      "id": "email_mark_seen",
      "name": "Mark Email Read",
      "type": "imap_mark_seen",
      "address": "192.168.8.101",
      "username": "secret",
      "password": "secret",
      "path": "INBOX",
      "insecure": true
    }
  ]
}
