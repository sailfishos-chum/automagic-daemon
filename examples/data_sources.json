{
  "version": 1,
  "data": [
    {
      "id": "startup_timer",
      "name": "Startup Timer",
      "type": "timer",
      "interval": "0s",
      "initial_delay": "0s",
      "enabled": true,
      "trigger": true
    },
    {
      "id": "timer_15m",
      "name": "15 Minute Timer",
      "type": "timer",
      "interval": "15m",
      "initial_delay": "15s",
      "enabled": false,
      "trigger": true
    },
    {
      "id": "system_hostname",
      "name": "System Hostname",
      "type": "file",
      "format": "raw",
      "path": "/proc/sys/kernel/hostname",
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "hostname"
        }
      ]
    },
    {
      "id": "dbus_hostname",
      "name": "DBus System Hostname",
      "type": "dbus",
      "enabled": true,
      "address": "system",
      "destination": "org.freedesktop.hostname1",
      "path": "/org/freedesktop/hostname1",
      "interface": "org.freedesktop.DBus.Properties",
      "method": "Get",
      "args": [
        { "type": "string", "value": "org.freedesktop.hostname1" },
        { "type": "string", "value": "Hostname" }
      ],
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "dbus_host"
        }
      ]
    },
    {
      "id": "battery_status",
      "name": "Battery Level",
      "type": "dbus",
      "address": "system",
      "destination": "com.nokia.mce",
      "path": "/com/nokia/mce/request",
      "interface": "com.nokia.mce.request",
      "method": "get_battery_level",
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "battery_level"
        }
      ]
    },
    {
      "id": "battery_signal",
      "name": "Battery Level (Live)",
      "type": "dbus",
      "address": "system",
      "enabled": true,
      "trigger": true,
      "path": "/com/nokia/mce/signal",
      "interface": "com.nokia.mce.signal",
      "signal": "battery_level_ind",
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "battery_level"
        }
      ]
    },
    {
      "id": "media_player_status",
      "name": "Media Status (Trigger)",
      "type": "dbus",
      "address": "session",
      "enabled": true,
      "trigger": true,
      "path": "/org/mpris/MediaPlayer2",
      "interface": "org.freedesktop.DBus.Properties",
      "signal": "PropertiesChanged",
      "filters": {
        "arg0": "org.mpris.MediaPlayer2.Player"
      },
      "transformations": [
        {
          "type": "copy",
          "optional": true,
          "in": "arg1/PlaybackStatus",
          "out": "media_player_status"
        },
        {
          "optional": true,
          "type": "copy",
          "in": "arg1/Metadata/xesam:title",
          "out": "track_title"
        }
      ]
    },
    {
      "id": "incoming_sms",
      "name": "Incoming SMS",
      "type": "dbus",
      "enabled": false,
      "trigger": true,
      "address": "system",
      "path": "/ril_0",
      "interface": "org.ofono.MessageManager",
      "signal": "IncomingMessage",
      "transformations": [
        { 
          "type": "copy", 
          "in": "arg0", 
          "out": "sms_text" 
        },
        { 
          "type": "copy", 
          "in": "arg1/Sender", 
          "out": "sms_sender" 
        }
      ]
    },
    {
      "id": "web_status",
      "name": "Web Status",
      "type": "http",
      "address": "https://qml.app/automagic/status.json",
      "enabled": true,
      "transformations": [
        {
          "type": "copy",
          "in": "value",
          "out": "web_status"
        }
      ]
    },
    {
      "id": "temperature_humidity",
      "name": "433 MHz Weather Sensors",
      "type": "mqtt",
      "enabled": false,
      "trigger": true,
      "address": "192.168.8.12:1883",
      "username": "super",
      "password": "secret",
      "topic": "rtl_433/#",
      "format": "json",
      "filters": {"model": "*", "id": "*", "temperature_F": "*"},
      "transformations": [
        {
          "type": "template",
          "in": "{{model}}_{{id}}_{{channel}}",
          "out": "raw_sensor_id"
        },
        {
          "type": "value_map",
          "map": "sensors",
          "in": "raw_sensor_id",
          "out": "sensor_id"
        },
        {
          "type": "math",
          "in": "({{temperature_F}} - 32) * 5 / 9",
          "out": "temperature", 
          "optional": true
        },
        {
          "type": "round",
          "in": "temperature",
          "out": "temperature",
          "decimal_places": 2
        },
        {
          "type": "copy",
          "in": "humidity",
          "out": "humidity", 
          "optional": true
        }
      ]
    },
    {
      "id": "state_change_media_player_status",
      "name": "State Change",
      "type": "state",
      "enabled": true,
      "trigger": true,
      "filters": {"state_key": "media_player_status"},
      "transformations": [
        {
          "type": "copy",
          "in": "state_key",
          "out": "state_key"
        },
        {
          "type": "copy",
          "in": "state_value",
          "out": "state_value"
        }
      ]
    },
    {
      "id": "read_sqlite_sales",
      "name": "Last Sales from Database",
      "path": "/home/defaultuser/Documents/sales.sqlite",
      "query": "SELECT sold, total FROM phone_stats ORDER BY id DESC LIMIT 1",
      "transformations": [
        {
          "in": "sold",
          "out": "phones_sold",
          "type": "copy",
          "optional": true
        },
        {
          "in": "total",
          "out": "phones_total",
          "type": "copy",
          "optional": true
        }
      ],
      "type": "sqlite",
      "trigger": false,
      "enabled": true
    },
    {
      "id": "read_temperature_mysql",
      "name": "Last Temperature",
      "type": "mysql",
      "address": "192.168.8.12",
      "database": "sensordata",
      "username": "secret",
      "password": "secret",
      "query": "SELECT created_at,sensor_id,temperature FROM temperatures ORDER BY created_at DESC LIMIT 1",
      "transformations": [
        {
          "type": "value_map",
          "map": "sensors",
          "in": "sensor_id",
          "out": "temperature_sensor_id"
        },
        {
          "type": "copy",
          "in": "temperature",
          "out": "temperature"
        }
      ]
    },
    {
      "id": "imap_source",
      "name": "IMAP Mailbox",
      "type": "imap",
      "address": "192.168.8.101",
      "username": "secret",
      "password": "secret",
      "path": "INBOX",
      "insecure": true,
      "enabled": true,
      "format": "split",
      "delimiter": "\n",
      "transformations": [
        {
          "type": "copy",
          "in": "uid",
          "out": "email_uid",
          "optional": true
        },
        {
          "type": "copy",
          "in": "text/plain/arg0",
          "out": "body1",
          "optional": true
        },
        {
          "type": "copy",
          "in": "from",
          "out": "email_from",
          "optional": true
        },
        {
          "type": "copy",
          "in": "to",
          "out": "email_to",
          "optional": true
        },
        {
          "type": "copy",
          "in": "subject",
          "out": "email_subject",
          "optional": true
        }
      ]
    }
  ]
}
