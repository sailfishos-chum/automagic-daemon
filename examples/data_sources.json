{
  "version": 1,
  "data": [
    {
      "id": "startup_timer",
      "name": "Startup Timer",
      "type": "timer",
      "interval": "0s",
      "initial_delay": "0s",
      "enabled": true,
      "trigger": true
    },
    {
      "id": "system_hostname",
      "name": "System Hostname",
      "type": "file",
      "format": "raw",
      "path": "/proc/sys/kernel/hostname",
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "hostname"
        }
      ]
    },
    {
      "id": "battery_signal",
      "name": "Battery Level",
      "type": "dbus",
      "address": "system",
      "enabled": true,
      "trigger": true,
      "path": "/com/nokia/mce/signal",
      "interface": "com.nokia.mce.signal",
      "signal": "battery_level_ind",
      "transformations": [
        {
          "type": "copy",
          "in": "arg0",
          "out": "battery_level"
        }
      ]
    }
  ]
}
